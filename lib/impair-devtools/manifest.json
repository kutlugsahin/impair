{
  "manifest_version": 3,
  "name": "Impair DevTools",
  "version": "1.0.0",
  "description": "DevTools extension for Impair - inspect ServiceProvider hierarchy and reactive state",
  "devtools_page": "devtools-page.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "icons": {}
}
